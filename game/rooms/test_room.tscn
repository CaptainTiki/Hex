[sub_resource type="Shader" id="Shader_far_background_gradient"]
code = "shader_type spatial;
render_mode unshaded, cull_disabled;

uniform vec4 top_color : source_color = vec4(0.115, 0.120, 0.230, 1.0);
uniform vec4 center_color : source_color = vec4(0.246, 0.245, 0.414, 1.0);
uniform vec4 bottom_color : source_color = vec4(0.095, 0.090, 0.190, 1.0);
uniform float center_width = 0.9;

void fragment() {
	float vertical = UV.y;
	float center_weight = smoothstep(0.0, center_width, vertical) * smoothstep(1.0, center_width, vertical);
	vec4 edge_color = mix(bottom_color, top_color, vertical);
	ALBEDO = mix(edge_color.rgb, center_color.rgb, center_weight);
	EMISSION = ALBEDO * 0.55;
}"

